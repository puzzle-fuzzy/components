{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "paths": {
      "@puzzle-fuzzy/ui": ["../../packages/ui/src/index.ts"],
      "@puzzle-fuzzy/ui/*": ["../../packages/ui/src/components/*/index.ts"],
      "@puzzle-fuzzy/ui/styles.css": ["../../packages/ui/src/styles/index.less"]
    },
    "tsBuildInfoFile": "../../node_modules/.cache/typescript/docs.tsbuildinfo",
    "types": ["node", "vitepress/client"]
  },
  "include": [
    "docs/.vitepress/**/*.ts",
    "docs/.vitepress/**/*.mts",
    "docs/.vitepress/**/*.vue",
    "examples/**/*.vue",
    "tests/**/*.ts",
    "playwright.config.ts",
    "../../packages/ui/src/**/*.ts",
    "../../packages/ui/src/**/*.vue"
  ],
  "exclude": ["../../packages/ui/src/**/__tests__/**", "../../packages/ui/src/**/*.test.ts"]
}
