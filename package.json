{
  "name": "omg-ui-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "pnpm --filter @puzzle-fuzzy/ui build",
    "check": "pnpm format:check && pnpm lint && pnpm lint:styles && pnpm check:naming && pnpm typecheck && pnpm test:coverage",
    "check:naming": "node scripts/check-naming.mjs",
    "docs:build": "pnpm build && pnpm --filter @puzzle-fuzzy/docs docs:build",
    "docs:dev": "pnpm --filter @puzzle-fuzzy/docs docs:dev",
    "docs:preview": "pnpm --filter @puzzle-fuzzy/docs docs:preview",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint . --max-warnings 0",
    "lint:styles": "stylelint \"packages/ui/src/**/*.{vue,less}\" \"apps/docs/**/*.{vue,less}\"",
    "test": "vitest run packages/ui/src",
    "test:coverage": "vitest run packages/ui/src --coverage",
    "test:e2e": "pnpm docs:build && pnpm --filter @puzzle-fuzzy/docs test:e2e",
    "test:package": "node scripts/test-package.mjs",
    "test:ssr": "vitest run packages/ui/tests/ssr",
    "typecheck": "pnpm -r --if-present typecheck",
    "verify": "pnpm check && pnpm build && pnpm test:ssr && pnpm test:package && pnpm test:e2e"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.3",
    "@vitejs/plugin-vue": "catalog:",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/server-renderer": "catalog:",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "jsdom": "^28.0.0",
    "less": "catalog:",
    "postcss-html": "^1.8.0",
    "postcss-less": "^6.0.0",
    "prettier": "^3.9.0",
    "publint": "^0.3.18",
    "stylelint": "^17.5.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard-less": "^4.0.0",
    "tar": "7.5.11",
    "typescript": "catalog:",
    "typescript-eslint": "^8.57.0",
    "vite": "catalog:",
    "vitest": "^4.1.10",
    "vue": "catalog:",
    "vue-tsc": "catalog:"
  }
}
