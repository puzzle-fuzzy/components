{
  "name": "@puzzle-fuzzy/ui",
  "version": "0.1.0",
  "description": "OMG UI — a personal Vue 3 component library",
  "keywords": [
    "vue",
    "vue3",
    "component-library",
    "ui",
    "omg-ui"
  ],
  "homepage": "https://github.com/puzzle-fuzzy/components#readme",
  "bugs": {
    "url": "https://github.com/puzzle-fuzzy/components/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/puzzle-fuzzy/components.git",
    "directory": "packages/ui"
  },
  "private": false,
  "type": "module",
  "license": "UNLICENSED",
  "files": [
    "dist"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./button": {
      "types": "./dist/components/button/index.d.ts",
      "import": "./dist/components/button/index.js"
    },
    "./avatar": {
      "types": "./dist/components/avatar/index.d.ts",
      "import": "./dist/components/avatar/index.js"
    },
    "./avatar-group": {
      "types": "./dist/components/avatar-group/index.d.ts",
      "import": "./dist/components/avatar-group/index.js"
    },
    "./avatar-flow": {
      "types": "./dist/components/avatar-flow/index.d.ts",
      "import": "./dist/components/avatar-flow/index.js"
    },
    "./code-input": {
      "types": "./dist/components/code-input/index.d.ts",
      "import": "./dist/components/code-input/index.js"
    },
    "./divider": {
      "types": "./dist/components/divider/index.d.ts",
      "import": "./dist/components/divider/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "sideEffects": [
    "./dist/styles.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm typecheck && vite build && pnpm build:types",
    "build:types": "vue-tsc -p tsconfig.build.json",
    "prepack": "pnpm build",
    "typecheck": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "catalog:",
    "less": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vue": "catalog:",
    "vue-tsc": "catalog:"
  }
}
