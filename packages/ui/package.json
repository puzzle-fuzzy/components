{
  "name": "@components/ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/components-ui.umd.cjs",
  "module": "./dist/components-ui.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/components-ui.es.js",
      "require": "./dist/components-ui.umd.cjs"
    },
    "./style.css": "./dist/components-ui.css"
  },
  "sideEffects": [
    "*.css",
    "*.vue"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vueuse/core": "^14.3.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "less": "^4.6.7",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vite-plugin-dts": "^5.0.3",
    "vue": "^3.5.39",
    "vue-tsc": "^3.3.5"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  }
}